{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TXTeditor",
  "version": "0.4.4",
  "identifier": "com.yinyin333333.txteditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TXTeditor",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 560,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "publisher": "yinyin333333",
    "copyright": "Copyright (c) yinyin333333",
    "shortDescription": "Fast tabular text editor",
    "longDescription": "A canvas-virtualized desktop editor for Diablo II-style tab-separated text files."
  }
}
